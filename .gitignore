# Local secrets and environment overrides
.env
.env.*
!.env.example
!.env.template

# Review-tool generated runtime data
.cache/*
!.cache/.gitkeep
output/*
!output/.gitkeep

# Local project notes not published to GitHub
README.md
docs/

