__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Test and coverage output
.coverage
.coverage.*
coverage.xml
htmlcov/

# Build and packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Logs and temporary files
*.log
*.tmp
*.temp

# Editor, IDE, and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local assistant/tool settings
.claude/settings.local.json
